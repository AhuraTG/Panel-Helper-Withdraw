{
  "manifest_version": 3,
  "name": "Panel Helper",
  "version": "1.1",
  "description": "(Ahura) Ticket",
  "permissions": ["activeTab"],

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_title": "Panel Helper",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}